{
  "root": {
    "tag": "html",
    "attrs": { "lang": "es" },
    "children": [
      {
        "tag": "head",
        "children": [
          { "tag": "meta", "attrs": { "charset": "UTF-8" } },
          { "tag": "meta", "attrs": { "name": "viewport", "content": "width=device-width, initial-scale=1" } },
          { "tag": "title", "text": "Gator Mail" },
          { "tag": "link", "attrs": { "rel": "icon", "href": "/eimg/softgator/favicon-softgator.png" } },
          { "tag": "link", "attrs": { "rel": "stylesheet", "href": "/elib/css2/bootstrap-5.3.0/bootstrap.min.css" } },
          { "tag": "link", "attrs": { "rel": "stylesheet", "href": "/elib/css2/fontawesome-free-5.13.0-web/css/all.min.css" } },
          { "tag": "link", "attrs": { "rel": "stylesheet", "href": "/elib/css/colors.css" } },
          { "tag": "link", "attrs": { "rel": "stylesheet", "href": "${contextPath}/css/gator-mail.css?v=26" } },
          { "tag": "script", "attrs": { "src": "/elib/js/sweetalert2.all.min.js", "defer": "true" } },
          { "tag": "script", "attrs": { "src": "${contextPath}/js/gator-mail.js?v=7", "defer": "true" } }
        ]
      },
      {
        "tag": "body",
        "attrs": { "class": "mail-app" },
        "children": [
          {
            "tag": "header",
            "attrs": { "class": "navbar navbar-light mail-topbar" },
            "children": [
              {
                "tag": "div",
                "attrs": { "class": "container-fluid" },
                "children": [
                  { "tag": "a", "attrs": { "class": "navbar-brand mail-brand", "href": "${contextPath}/mail" }, "children": [
                    { "tag": "img", "attrs": { "class": "mail-logo", "src": "/eimg/softGatorNewAlone.png", "alt": "SoftGator" } },
                    { "tag": "span", "text": "Gator Mail" }
                  ] },
                  {
                    "tag": "div",
                    "if": "sessionActive",
                    "attrs": { "class": "mail-account" },
                    "children": [
                      { "tag": "span", "attrs": { "class": "mail-account-address" }, "text": "${mailbox}" },
                      { "tag": "a", "attrs": { "class": "btn btn-sm mail-signout", "href": "${accountHref}", "title": "Administrar contraseña" }, "children": [
                        { "tag": "span", "attrs": { "class": "fas fa-key", "aria-hidden": "true" } },
                        { "tag": "span", "attrs": { "class": "mail-password-label" }, "text": "Contraseña" }
                      ] },
                      { "tag": "a", "attrs": { "class": "btn btn-sm mail-signout", "href": "${contextPath}/oauth/logout" }, "children": [
                        { "tag": "span", "attrs": { "class": "fas fa-sign-out-alt", "aria-hidden": "true" } },
                        { "tag": "span", "text": "Cerrar sesión" }
                      ] }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "tag": "div",
            "attrs": { "class": "${layoutClass}" },
            "children": [
              {
                "tag": "nav",
                "if": "mailContent",
                "attrs": { "class": "mail-sidebar", "aria-label": "Carpetas de correo" },
                "children": [
                  { "tag": "p", "attrs": { "class": "mail-sidebar-kicker" }, "text": "Tu correo" },
                  { "tag": "h2", "attrs": { "class": "mail-sidebar-title", "data-drop-root": "true" }, "text": "Carpetas" },
                  { "tag": "details", "attrs": { "class": "mail-folder-group", "open": "${mailOpen}" }, "children": [
                    { "tag": "summary", "attrs": { "class": "mail-folder mail-folder-parent" }, "children": [
                      { "tag": "strong", "children": [
                        { "tag": "span", "attrs": { "class": "mail-folder-icon fas fa-envelope", "aria-hidden": "true" } },
                        { "tag": "span", "text": "Correo" }
                      ] }
                    ] },
                    { "tag": "div", "each": "folderGroups", "as": "group", "children": [
                    { "tag": "details", "if": "group.hasChildren", "attrs": { "class": "mail-folder-group", "open": "${group.open}" }, "children": [
                      { "tag": "summary", "attrs": { "class": "mail-folder mail-folder-parent", "draggable": "${group.draggable}", "data-folder": "${group.folder}", "data-csrf": "${csrf}" }, "children": [
                        { "tag": "strong", "children": [
                          { "tag": "span", "attrs": { "class": "mail-folder-icon ${group.icon}", "aria-hidden": "true" } },
                          { "tag": "span", "text": "${group.label}" }
                        ] },
                        { "tag": "small", "text": "${group.count}" }
                      ] },
                      { "tag": "a", "each": "group.children", "as": "folder", "attrs": { "class": "mail-folder ${folder.className}", "href": "${folder.href}", "draggable": "${folder.draggable}", "data-folder": "${folder.folder}", "data-csrf": "${csrf}" }, "children": [
                        { "tag": "strong", "children": [
                          { "tag": "span", "attrs": { "class": "mail-folder-icon ${folder.icon}", "aria-hidden": "true" } },
                          { "tag": "span", "text": "${folder.label}" }
                        ] },
                        { "tag": "small", "text": "${folder.count}" }
                      ] }
                    ] },
                    { "tag": "a", "if": "group.leaf", "attrs": { "class": "mail-folder ${group.className}", "href": "${group.href}", "draggable": "${group.draggable}", "data-folder": "${group.folder}", "data-csrf": "${csrf}" }, "children": [
                      { "tag": "strong", "children": [
                        { "tag": "span", "attrs": { "class": "mail-folder-icon ${group.icon}", "aria-hidden": "true" } },
                        { "tag": "span", "text": "${group.label}" }
                      ] },
                      { "tag": "small", "text": "${group.count}" }
                    ] }
                    ] }
                  ] },
                  { "tag": "a", "attrs": { "class": "mail-folder ${calendarClass}", "href": "${contextPath}/mail?action=calendar" }, "children": [
                    { "tag": "strong", "children": [
                      { "tag": "span", "attrs": { "class": "mail-folder-icon fas fa-calendar-alt", "aria-hidden": "true" } },
                      { "tag": "span", "text": "Calendario" }
                    ] }
                  ] },
                  { "tag": "details", "if": "configurationAvailable", "attrs": { "class": "mail-folder-group mail-configuration", "open": "${configurationOpen}" }, "children": [
                    { "tag": "summary", "attrs": { "class": "mail-folder mail-folder-parent" }, "children": [
                      { "tag": "strong", "children": [
                        { "tag": "span", "attrs": { "class": "mail-folder-icon fas fa-cog", "aria-hidden": "true" } },
                        { "tag": "span", "text": "Configuración" }
                      ] }
                    ] },
                    { "tag": "a", "attrs": { "class": "mail-folder mail-folder-child ${configurationUsersClass}", "href": "${contextPath}/mail?action=settings&section=users" }, "children": [
                      { "tag": "strong", "children": [
                        { "tag": "span", "attrs": { "class": "mail-folder-icon fas fa-users", "aria-hidden": "true" } },
                        { "tag": "span", "text": "Usuarios" }
                      ] }
                    ] },
                    { "tag": "a", "attrs": { "class": "mail-folder mail-folder-child ${configurationContactsClass}", "href": "${contextPath}/mail?action=settings&section=contacts" }, "children": [
                      { "tag": "strong", "children": [
                        { "tag": "span", "attrs": { "class": "mail-folder-icon fas fa-address-book", "aria-hidden": "true" } },
                        { "tag": "span", "text": "Contactos" }
                      ] }
                    ] }
                  ] },
                  { "tag": "div", "attrs": { "class": "mail-folder-menu", "id": "mail-folder-menu", "data-csrf": "${csrf}", "role": "menu" }, "children": [
                    { "tag": "button", "attrs": { "class": "mail-folder-menu-item", "id": "mail-folder-rename", "type": "button", "role": "menuitem" }, "children": [
                      { "tag": "span", "attrs": { "class": "fas fa-pen", "aria-hidden": "true" } }, { "tag": "span", "text": "Renombrar" }
                    ] },
                    { "tag": "button", "attrs": { "class": "mail-folder-menu-item mail-folder-menu-danger", "id": "mail-folder-delete", "type": "button", "role": "menuitem" }, "children": [
                      { "tag": "span", "attrs": { "class": "fas fa-trash-alt", "aria-hidden": "true" } }, { "tag": "span", "text": "Eliminar" }
                    ] }
                  ] }
                ]
              },
              {
                "tag": "main",
                "attrs": { "class": "${contentClass}" },
                "children": [
                  {
                    "tag": "section",
                    "if": "dashboardView",
                    "attrs": { "class": "mail-dashboard-grid" },
                    "children": [
                      { "tag": "section", "attrs": { "class": "card mail-panel" }, "children": [
                        { "tag": "header", "attrs": { "class": "card-header mail-panel-header" }, "children": [
                          { "tag": "div", "children": [
                            { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Calendario" },
                            { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "Eventos" }
                          ] }
                        ] },
                        { "tag": "p", "if": "eventsEmpty", "attrs": { "class": "mail-empty text-muted" }, "text": "No hay eventos en este periodo." },
                        { "tag": "div", "if": "eventsAvailable", "attrs": { "class": "mail-event-list" }, "children": [
                          { "tag": "div", "each": "events", "as": "event", "attrs": { "class": "mail-event ${event.statusClass}" }, "children": [
                            { "tag": "span", "attrs": { "class": "mail-event-icon fas fa-calendar-day", "aria-hidden": "true" } },
                            { "tag": "div", "attrs": { "class": "mail-event-copy" }, "children": [
                              { "tag": "strong", "text": "${event.summary}" },
                              { "tag": "p", "text": "${event.description}" },
                              { "tag": "small", "text": "Inicia: ${event.start} · Termina: ${event.end}" },
                              { "tag": "small", "if": "event.place", "text": "Lugar: ${event.place}" }
                            ] },
                            { "tag": "span", "attrs": { "class": "mail-event-status" }, "text": "${event.status}" }
                          ] }
                        ] }
                      ] },
                      { "tag": "section", "attrs": { "class": "card mail-panel mail-stats-panel" }, "children": [
                        { "tag": "header", "attrs": { "class": "card-header mail-panel-header" }, "children": [
                          { "tag": "div", "children": [
                            { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Entrada" },
                            { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "Resumen de correo" }
                          ] }
                        ] },
                        { "tag": "div", "attrs": { "class": "mail-stats" }, "children": [
                          { "tag": "div", "attrs": { "class": "mail-stat" }, "children": [
                            { "tag": "span", "attrs": { "class": "fas fa-envelope", "aria-hidden": "true" } },
                            { "tag": "strong", "text": "${mailTotal}" }, { "tag": "small", "text": "Total de correos" }
                          ] },
                          { "tag": "div", "attrs": { "class": "mail-stat is-unread" }, "children": [
                            { "tag": "span", "attrs": { "class": "fas fa-envelope", "aria-hidden": "true" } },
                            { "tag": "strong", "text": "${mailUnread}" }, { "tag": "small", "text": "No leídos" }
                          ] },
                          { "tag": "div", "attrs": { "class": "mail-stat is-read" }, "children": [
                            { "tag": "span", "attrs": { "class": "fas fa-envelope-open", "aria-hidden": "true" } },
                            { "tag": "strong", "text": "${mailRead}" }, { "tag": "small", "text": "Leídos" }
                          ] }
                        ] }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "calendarView",
                    "attrs": { "class": "card mail-panel mail-agenda" },
                    "children": [
                      { "tag": "header", "attrs": { "class": "card-header mail-panel-header" }, "children": [
                        { "tag": "a", "attrs": { "class": "btn btn-outline-secondary btn-sm", "href": "${calendarPrevious}", "aria-label": "Mes anterior" }, "children": [
                          { "tag": "span", "attrs": { "class": "fas fa-chevron-left", "aria-hidden": "true" } }
                        ] },
                        { "tag": "div", "attrs": { "class": "mail-agenda-title" }, "children": [
                          { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Agenda" },
                          { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "${calendarMonth}" }
                        ] },
                        { "tag": "a", "attrs": { "class": "btn btn-outline-secondary btn-sm", "href": "${calendarNext}", "aria-label": "Mes siguiente" }, "children": [
                          { "tag": "span", "attrs": { "class": "fas fa-chevron-right", "aria-hidden": "true" } }
                        ] }
                      ] },
                      { "tag": "div", "attrs": { "class": "mail-agenda-scroll" }, "children": [
                        { "tag": "div", "attrs": { "class": "mail-agenda-weekdays" }, "children": [
                          { "tag": "strong", "text": "Dom" }, { "tag": "strong", "text": "Lun" },
                          { "tag": "strong", "text": "Mar" }, { "tag": "strong", "text": "Mié" },
                          { "tag": "strong", "text": "Jue" }, { "tag": "strong", "text": "Vie" },
                          { "tag": "strong", "text": "Sáb" }
                        ] },
                        { "tag": "div", "attrs": { "class": "mail-agenda-days" }, "children": [
                          { "tag": "div", "each": "calendarDays", "as": "day", "attrs": { "class": "mail-agenda-day ${day.className}" }, "children": [
                            { "tag": "strong", "attrs": { "class": "mail-agenda-number" }, "text": "${day.number}" },
                            { "tag": "div", "each": "day.events", "as": "event", "attrs": { "class": "mail-agenda-event ${event.statusClass}", "title": "${event.description}" }, "text": "${event.time} ${event.summary}" }
                          ] }
                        ] }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "challenge",
                    "attrs": { "class": "card mail-state-card mail-auth-card" },
                    "children": [
                      {
                        "tag": "div",
                        "attrs": { "class": "card-body p-4" },
                        "children": [
                          { "tag": "span", "attrs": { "class": "mail-state-icon" }, "text": "✦" },
                          { "tag": "p", "attrs": { "class": "mail-eyebrow" }, "text": "Segundo paso" },
                          { "tag": "h1", "attrs": { "class": "mail-state-title" }, "text": "Confirma que eres tú" },
                          { "tag": "p", "attrs": { "class": "mail-state-copy" }, "text": "Enviamos una clave temporal por SMS al teléfono asociado con tu cuenta." },
                          { "tag": "span", "if": "noticeVisible", "attrs": { "class": "d-none mail-swal mail-swal-info", "title": "Aviso" }, "text": "${notice}" },
                          {
                            "tag": "form",
                            "attrs": { "method": "post", "class": "mail-challenge-form" },
                            "children": [
                              { "tag": "input", "attrs": { "type": "hidden", "name": "action", "value": "verify" } },
                              { "tag": "input", "attrs": { "type": "hidden", "name": "token", "value": "${token}" } },
                              { "tag": "label", "attrs": { "class": "form-label mail-code-label", "for": "code" }, "text": "Clave de verificación" },
                              { "tag": "input", "attrs": { "class": "form-control form-control-lg mail-code", "id": "code", "name": "code", "type": "text", "inputmode": "text", "autocomplete": "one-time-code", "placeholder": "Escribe la clave recibida", "pattern": "[A-Za-z0-9]{8,12}", "minlength": "8", "maxlength": "12", "required": "true", "autofocus": "true", "aria-label": "Clave alfanumérica de 8 a 12 caracteres" } },
                              { "tag": "small", "attrs": { "class": "mail-code-help" }, "text": "Puede contener letras y números." },
                              { "tag": "button", "attrs": { "class": "btn btn-primary btn-lg w-100 mail-primary-action", "type": "submit" }, "text": "Continuar" }
                            ]
                          },
                          {
                            "tag": "form",
                            "attrs": { "method": "post", "class": "mail-resend" },
                            "children": [
                              { "tag": "input", "attrs": { "type": "hidden", "name": "action", "value": "resend" } },
                              { "tag": "input", "attrs": { "type": "hidden", "name": "token", "value": "${token}" } },
                              { "tag": "button", "attrs": { "class": "btn btn-link", "type": "submit", "disabled": "${resendDisabled}" }, "text": "No recibí la clave" },
                              { "tag": "small", "attrs": { "class": "d-block text-muted" }, "text": "${resendWait}" }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "configurationUsersView",
                    "attrs": { "class": "card mail-panel" },
                    "children": [
                      { "tag": "header", "attrs": { "class": "card-header mail-panel-header" }, "children": [
                        { "tag": "div", "children": [
                          { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Configuración" },
                          { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "Usuarios" }
                        ] },
                        { "tag": "a", "attrs": { "class": "btn btn-outline-secondary btn-sm", "href": "${contextPath}/mail" }, "text": "Volver al correo" }
                      ] },
                      { "tag": "div", "attrs": { "class": "mail-admin-list" }, "children": [
                        { "tag": "form", "each": "configurationUsers", "as": "user", "attrs": { "class": "mail-admin-row mail-admin-user", "method": "post" }, "children": [
                          { "tag": "input", "attrs": { "type": "hidden", "name": "csrf", "value": "${csrf}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "user", "value": "${user.id}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "enabled", "value": "${user.enabled}" } },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Usuario" }, { "tag": "strong", "text": "${user.id}" }] },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Nombre" }, { "tag": "input", "attrs": { "class": "form-control", "name": "name", "value": "${user.name}", "maxlength": "200" } }] },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Correo" }, { "tag": "strong", "text": "${user.email}" }] },
                          { "tag": "span", "attrs": { "class": "mail-admin-status" }, "text": "${user.status}" },
                          { "tag": "div", "attrs": { "class": "mail-admin-actions" }, "children": [
                            { "tag": "button", "attrs": { "class": "btn btn-primary btn-sm", "type": "submit", "name": "action", "value": "userSave" }, "text": "Guardar" },
                            { "tag": "button", "attrs": { "class": "btn btn-outline-secondary btn-sm", "type": "submit", "name": "action", "value": "userToggle" }, "text": "${user.toggleLabel}" }
                          ] }
                        ] }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "configurationContactsView",
                    "attrs": { "class": "card mail-panel" },
                    "children": [
                      { "tag": "header", "attrs": { "class": "card-header mail-panel-header" }, "children": [
                        { "tag": "div", "children": [
                          { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Configuración" },
                          { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "Contactos" }
                        ] },
                        { "tag": "a", "attrs": { "class": "btn btn-outline-secondary btn-sm", "href": "${contextPath}/mail" }, "text": "Volver al correo" }
                      ] },
                      { "tag": "form", "attrs": { "class": "mail-admin-row mail-admin-contact mail-admin-new", "method": "post" }, "children": [
                        { "tag": "input", "attrs": { "type": "hidden", "name": "csrf", "value": "${csrf}" } },
                        { "tag": "input", "attrs": { "type": "hidden", "name": "id", "value": "" } },
                        { "tag": "label", "children": [{ "tag": "small", "text": "Nombre" }, { "tag": "input", "attrs": { "class": "form-control", "name": "name", "maxlength": "200", "required": "true" } }] },
                        { "tag": "label", "children": [{ "tag": "small", "text": "Correo" }, { "tag": "input", "attrs": { "class": "form-control", "name": "email", "type": "email", "maxlength": "320", "required": "true" } }] },
                        { "tag": "label", "children": [{ "tag": "small", "text": "Usuario propietario" }, { "tag": "input", "attrs": { "class": "form-control", "name": "owner" } }] },
                        { "tag": "label", "children": [{ "tag": "small", "text": "Grupos (IDs)" }, { "tag": "input", "attrs": { "class": "form-control", "name": "group", "placeholder": "2, 3" } }] },
                        { "tag": "button", "attrs": { "class": "btn btn-primary btn-sm", "type": "submit", "name": "action", "value": "contactSave" }, "text": "Agregar contacto" }
                      ] },
                      { "tag": "div", "attrs": { "class": "mail-admin-list" }, "children": [
                        { "tag": "form", "each": "configurationContacts", "as": "contact", "attrs": { "class": "mail-admin-row mail-admin-contact", "method": "post" }, "children": [
                          { "tag": "input", "attrs": { "type": "hidden", "name": "csrf", "value": "${csrf}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "id", "value": "${contact.id}" } },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Nombre" }, { "tag": "input", "attrs": { "class": "form-control", "name": "name", "value": "${contact.name}", "maxlength": "200", "required": "true" } }] },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Correo" }, { "tag": "input", "attrs": { "class": "form-control", "name": "email", "type": "email", "value": "${contact.email}", "maxlength": "320", "required": "true" } }] },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Usuario propietario" }, { "tag": "input", "attrs": { "class": "form-control", "name": "owner", "value": "${contact.owner}" } }] },
                          { "tag": "label", "children": [{ "tag": "small", "text": "Grupos (IDs)" }, { "tag": "input", "attrs": { "class": "form-control", "name": "group", "value": "${contact.group}", "placeholder": "2, 3" } }] },
                          { "tag": "div", "attrs": { "class": "mail-admin-actions" }, "children": [
                            { "tag": "button", "attrs": { "class": "btn btn-primary btn-sm", "type": "submit", "name": "action", "value": "contactSave" }, "text": "Guardar" },
                            { "tag": "button", "attrs": { "class": "btn btn-outline-danger btn-sm", "type": "submit", "name": "action", "value": "contactDelete" }, "text": "Eliminar" }
                          ] }
                        ] }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "composeView",
                    "attrs": { "class": "card mail-panel" },
                    "children": [
                      { "tag": "header", "attrs": { "class": "card-header mail-panel-header" }, "children": [
                        { "tag": "div", "children": [
                          { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Markdown" },
                          { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "Nuevo mensaje" }
                        ] },
                        { "tag": "a", "attrs": { "class": "btn btn-outline-secondary btn-sm", "href": "${contextPath}/mail" }, "text": "Cancelar" }
                      ] },
                      { "tag": "form", "attrs": { "class": "mail-compose-form", "method": "post", "enctype": "multipart/form-data" }, "children": [
                        { "tag": "input", "attrs": { "type": "hidden", "name": "csrf", "value": "${csrf}" } },
                        { "tag": "div", "attrs": { "class": "mail-recipient-field" }, "children": [
                          { "tag": "label", "attrs": { "class": "form-label", "for": "mail-compose-to" }, "text": "Para" },
                          { "tag": "div", "attrs": { "class": "mail-recipient-control" }, "children": [
                            { "tag": "input", "attrs": { "class": "form-control", "id": "mail-compose-to", "name": "to", "type": "text", "value": "${composeTo}", "placeholder": "destinatario@dominio.com", "required": "true", "autocomplete": "off" } },
                            { "tag": "button", "if": "contactsAvailable", "attrs": { "class": "btn btn-outline-secondary mail-contact-open", "type": "button", "data-contact-target": "mail-compose-to", "aria-controls": "mail-contact-picker", "aria-expanded": "false", "title": "Seleccionar contactos para Para" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-address-book", "aria-hidden": "true" } },
                              { "tag": "span", "text": "Contactos" }
                            ] }
                          ] }
                        ] },
                        { "tag": "div", "attrs": { "class": "mail-recipient-field" }, "children": [
                          { "tag": "label", "attrs": { "class": "form-label", "for": "mail-compose-cc" }, "text": "CC" },
                          { "tag": "div", "attrs": { "class": "mail-recipient-control" }, "children": [
                            { "tag": "input", "attrs": { "class": "form-control", "id": "mail-compose-cc", "name": "cc", "type": "text", "value": "${composeCc}", "placeholder": "Con copia", "autocomplete": "off" } },
                            { "tag": "button", "if": "contactsAvailable", "attrs": { "class": "btn btn-outline-secondary mail-contact-open", "type": "button", "data-contact-target": "mail-compose-cc", "aria-controls": "mail-contact-picker", "aria-expanded": "false", "title": "Seleccionar contactos para CC" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-address-book", "aria-hidden": "true" } },
                              { "tag": "span", "text": "Contactos" }
                            ] }
                          ] }
                        ] },
                        { "tag": "div", "attrs": { "class": "mail-recipient-field" }, "children": [
                          { "tag": "label", "attrs": { "class": "form-label", "for": "mail-compose-bcc" }, "text": "CCO" },
                          { "tag": "div", "attrs": { "class": "mail-recipient-control" }, "children": [
                            { "tag": "input", "attrs": { "class": "form-control", "id": "mail-compose-bcc", "name": "bcc", "type": "text", "value": "${composeBcc}", "placeholder": "Con copia oculta", "autocomplete": "off" } },
                            { "tag": "button", "if": "contactsAvailable", "attrs": { "class": "btn btn-outline-secondary mail-contact-open", "type": "button", "data-contact-target": "mail-compose-bcc", "aria-controls": "mail-contact-picker", "aria-expanded": "false", "title": "Seleccionar contactos para CCO" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-address-book", "aria-hidden": "true" } },
                              { "tag": "span", "text": "Contactos" }
                            ] }
                          ] }
                        ] },
                        { "tag": "section", "if": "contactsAvailable", "attrs": { "class": "mail-contact-picker", "id": "mail-contact-picker", "aria-label": "Directorio de contactos" }, "children": [
                          { "tag": "header", "attrs": { "class": "mail-contact-picker-header" }, "children": [
                            { "tag": "strong", "text": "Contactos" },
                            { "tag": "input", "attrs": { "class": "form-control form-control-sm", "id": "mail-contact-search", "type": "search", "placeholder": "Buscar contacto", "aria-label": "Buscar contacto" } },
                            { "tag": "button", "attrs": { "class": "btn btn-sm btn-light", "id": "mail-contact-close", "type": "button", "title": "Cerrar contactos" }, "children": [{ "tag": "span", "attrs": { "class": "fas fa-times", "aria-hidden": "true" } }] }
                          ] },
                          { "tag": "div", "attrs": { "class": "mail-contact-list" }, "children": [
                            { "tag": "button", "each": "contacts", "as": "contact", "attrs": { "class": "mail-contact-item", "type": "button", "data-contact-email": "${contact.email}" }, "children": [
                              { "tag": "strong", "text": "${contact.name}" },
                              { "tag": "small", "text": "${contact.email}" }
                            ] }
                          ] }
                        ] },
                        { "tag": "label", "attrs": { "class": "form-label", "for": "mail-compose-subject" }, "text": "Asunto" },
                        { "tag": "input", "attrs": { "class": "form-control", "id": "mail-compose-subject", "name": "subject", "type": "text", "value": "${composeSubject}", "maxlength": "200" } },
                        { "tag": "div", "attrs": { "class": "mail-md-toolbar", "role": "toolbar", "aria-label": "Formato Markdown" }, "children": [
                          { "tag": "button", "attrs": { "class": "btn btn-sm btn-light", "type": "button", "data-md": "bold", "title": "Negritas" }, "children": [{ "tag": "span", "attrs": { "class": "fas fa-bold", "aria-hidden": "true" } }] },
                          { "tag": "button", "attrs": { "class": "btn btn-sm btn-light", "type": "button", "data-md": "italic", "title": "Cursivas" }, "children": [{ "tag": "span", "attrs": { "class": "fas fa-italic", "aria-hidden": "true" } }] },
                          { "tag": "button", "attrs": { "class": "btn btn-sm btn-light", "type": "button", "data-md": "heading", "title": "Encabezado" }, "text": "H" },
                          { "tag": "button", "attrs": { "class": "btn btn-sm btn-light", "type": "button", "data-md": "list", "title": "Lista" }, "children": [{ "tag": "span", "attrs": { "class": "fas fa-list", "aria-hidden": "true" } }] },
                          { "tag": "button", "attrs": { "class": "btn btn-sm btn-light", "type": "button", "data-md": "link", "title": "Enlace" }, "children": [{ "tag": "span", "attrs": { "class": "fas fa-link", "aria-hidden": "true" } }] },
                          { "tag": "span", "attrs": { "class": "mail-md-label" }, "children": [
                            { "tag": "span", "attrs": { "class": "fab fa-markdown", "aria-hidden": "true" } }, { "tag": "span", "text": "Markdown" }
                          ] }
                        ] },
                        { "tag": "label", "attrs": { "class": "visually-hidden", "for": "mail-compose-body" }, "text": "Contenido" },
                        { "tag": "textarea", "attrs": { "class": "form-control mail-md-editor", "id": "mail-compose-body", "name": "body", "rows": "18", "spellcheck": "true", "required": "true", "placeholder": "Escribe tu mensaje con Markdown…" }, "text": "${composeBody}" },
                        { "tag": "div", "attrs": { "class": "mail-file-fields" }, "children": [
                          { "tag": "label", "attrs": { "class": "mail-file-field", "for": "mail-compose-attachments" }, "children": [
                            { "tag": "span", "attrs": { "class": "fas fa-paperclip", "aria-hidden": "true" } }, { "tag": "span", "text": "Adjuntar archivos" },
                            { "tag": "input", "attrs": { "id": "mail-compose-attachments", "name": "attachments", "type": "file", "multiple": "true" } }
                          ] },
                          { "tag": "label", "attrs": { "class": "mail-file-field", "for": "mail-compose-images" }, "children": [
                            { "tag": "span", "attrs": { "class": "fas fa-image", "aria-hidden": "true" } }, { "tag": "span", "text": "Incluir imágenes" },
                            { "tag": "input", "attrs": { "id": "mail-compose-images", "name": "images", "type": "file", "accept": "image/png,image/jpeg,image/gif", "multiple": "true" } }
                          ] }
                        ] },
                        { "tag": "div", "attrs": { "class": "mail-compose-footer" }, "children": [
                          { "tag": "small", "attrs": { "class": "text-muted" }, "text": "Se guardará como texto y HTML sanitizado en Borradores." },
                          { "tag": "div", "attrs": { "class": "mail-compose-actions" }, "children": [
                            { "tag": "button", "attrs": { "class": "btn btn-outline-primary", "type": "submit", "name": "action", "value": "saveDraft" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-save", "aria-hidden": "true" } }, { "tag": "span", "text": "Guardar borrador" }
                            ] },
                            { "tag": "button", "attrs": { "class": "btn btn-primary", "type": "submit", "name": "action", "value": "sendMessage" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-paper-plane", "aria-hidden": "true" } }, { "tag": "span", "text": "Enviar" }
                            ] }
                          ] }
                        ] }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "mailboxView",
                    "attrs": { "class": "card mail-panel" },
                    "children": [
                      {
                        "tag": "header",
                        "attrs": { "class": "card-header mail-panel-header" },
                        "children": [
                          { "tag": "div", "children": [
                            { "tag": "small", "attrs": { "class": "mail-eyebrow" }, "text": "Buzón" },
                            { "tag": "h1", "attrs": { "class": "mail-panel-title" }, "text": "${folderLabel}" }
                          ] },
                          { "tag": "div", "attrs": { "class": "mail-header-actions" }, "children": [
                            { "tag": "form", "attrs": { "class": "mail-search-form", "method": "get", "role": "search" }, "children": [
                              { "tag": "input", "attrs": { "type": "hidden", "name": "folder", "value": "${selectedFolder}" } },
                              { "tag": "input", "attrs": { "type": "hidden", "name": "size", "value": "${pageSize}" } },
                              { "tag": "input", "attrs": { "class": "form-control form-control-sm", "name": "q", "type": "search", "value": "${query}", "maxlength": "100", "placeholder": "Buscar correos", "aria-label": "Buscar correos" } },
                              { "tag": "button", "attrs": { "class": "btn btn-primary btn-sm", "type": "submit", "title": "Buscar" }, "children": [
                                { "tag": "span", "attrs": { "class": "fas fa-search", "aria-hidden": "true" } }
                              ] }
                            ] },
                            { "tag": "a", "attrs": { "class": "btn btn-outline-primary btn-sm mail-toolbar-action", "href": "${refreshHref}" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-sync-alt", "aria-hidden": "true" } },
                              { "tag": "span", "text": "Actualizar" }
                            ] }
                          ] }
                        ]
                      },
                      { "tag": "span", "if": "sendNotice", "attrs": { "class": "d-none mail-swal mail-swal-success", "title": "Mensaje enviado" }, "text": "El correo se envió correctamente." },
                      { "tag": "p", "if": "empty", "attrs": { "class": "mail-empty text-muted" }, "text": "${emptyText}" },
                      {
                        "tag": "form",
                        "if": "hasMessages",
                        "attrs": { "class": "mail-bulk-form", "id": "mail-bulk-form", "method": "post" },
                        "children": [
                          { "tag": "input", "attrs": { "type": "hidden", "name": "action", "value": "messageDelete" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "csrf", "value": "${csrf}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "folder", "value": "${selectedFolder}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "q", "value": "${query}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "page", "value": "${page}" } },
                          { "tag": "input", "attrs": { "type": "hidden", "name": "size", "value": "${pageSize}" } },
                          { "tag": "div", "attrs": { "class": "mail-bulk-toolbar" }, "children": [
                            { "tag": "input", "attrs": { "class": "form-check-input", "id": "mail-select-all", "type": "checkbox" } },
                            { "tag": "label", "attrs": { "for": "mail-select-all" }, "text": "Seleccionar todos" }
                          ] },
                          { "tag": "div", "attrs": { "class": "list-group list-group-flush" }, "children": [
                          {
                            "tag": "div",
                            "each": "messages",
                            "as": "message",
                            "attrs": { "class": "list-group-item mail-message-row ${message.stateClass}", "draggable": "true", "data-folder": "${message.folder}", "data-message-uid": "${message.uid}" },
                            "children": [
                              { "tag": "input", "attrs": { "class": "form-check-input mail-message-select", "type": "checkbox", "name": "uid", "value": "${message.uid}", "aria-label": "Seleccionar mensaje" } },
                              { "tag": "a", "attrs": { "class": "mail-message-link", "href": "${message.href}" }, "children": [
                                { "tag": "span", "attrs": { "class": "mail-message-icon fas ${message.icon}", "aria-hidden": "true" } },
                                { "tag": "div", "attrs": { "class": "mail-message-copy" }, "children": [
                                  { "tag": "div", "attrs": { "class": "mail-message-meta" }, "children": [
                                    { "tag": "strong", "text": "${message.from}" },
                                    { "tag": "time", "attrs": { "class": "text-muted" }, "text": "${message.sent}" },
                                    { "tag": "span", "attrs": { "class": "mail-message-state ${message.stateClass}" }, "text": "${message.state}" }
                                  ] },
                                  { "tag": "span", "attrs": { "class": "mail-subject" }, "text": "${message.subject}" }
                                ] }
                              ] }
                            ]
                          }
                          ] }
                        ]
                      }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "messageView",
                    "attrs": { "class": "card mail-panel" },
                    "children": [
                      {
                        "tag": "header",
                        "attrs": { "class": "card-header mail-panel-header" },
                        "children": [
                          { "tag": "a", "attrs": { "class": "btn btn-outline-primary btn-sm mail-toolbar-action", "href": "${folderHref}" }, "children": [
                            { "tag": "span", "attrs": { "class": "fas fa-chevron-left", "aria-hidden": "true" } },
                            { "tag": "span", "text": "${folderLabel}" }
                          ] },
                          { "tag": "small", "attrs": { "class": "text-muted" }, "text": "${sent}" }
                        ]
                      },
                      {
                        "tag": "div",
                        "attrs": { "class": "card-body mail-message" },
                        "children": [
                          { "tag": "h1", "attrs": { "class": "mail-message-title" }, "text": "${subject}" },
                          { "tag": "dl", "attrs": { "class": "mail-headers" }, "children": [
                            { "tag": "dt", "text": "De" }, { "tag": "dd", "text": "${from}" },
                            { "tag": "dt", "text": "Para" }, { "tag": "dd", "text": "${to}" }
                          ] },
                          { "tag": "section", "if": "attachmentsAvailable", "attrs": { "class": "mail-attachments", "aria-label": "Archivos adjuntos" }, "children": [
                            { "tag": "strong", "text": "Archivos adjuntos" },
                            { "tag": "a", "each": "attachments", "as": "attachment", "attrs": { "class": "mail-attachment", "href": "${attachment.href}" }, "children": [
                              { "tag": "span", "attrs": { "class": "fas fa-paperclip", "aria-hidden": "true" } },
                              { "tag": "span", "text": "${attachment.name}" }, { "tag": "small", "text": "${attachment.size}" }
                            ] }
                          ] },
                          { "tag": "pre", "if": "mailText", "attrs": { "class": "mail-body" }, "text": "${body}" },
                          { "tag": "iframe", "if": "mailHtml", "attrs": { "class": "mail-html-body", "sandbox": "", "referrerpolicy": "no-referrer", "title": "Contenido HTML del correo", "srcdoc": "${body}" } }
                        ]
                      }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "pending",
                    "attrs": { "class": "card mail-state-card" },
                    "children": [
                      { "tag": "div", "attrs": { "class": "card-body p-4" }, "children": [
                        { "tag": "span", "attrs": { "class": "mail-state-icon" }, "text": "…" },
                        { "tag": "h1", "attrs": { "class": "h4 mt-3" }, "text": "Tu buzón está pendiente" },
                        { "tag": "p", "attrs": { "class": "text-muted" }, "text": "La cuenta ya tiene acceso, pero el buzón aún no está disponible." },
                        { "tag": "a", "attrs": { "class": "btn btn-primary", "href": "${contextPath}/mail" }, "text": "Comprobar nuevamente" }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "error",
                    "attrs": { "class": "card mail-state-card" },
                    "children": [
                      { "tag": "div", "attrs": { "class": "card-body p-4" }, "children": [
                        { "tag": "span", "attrs": { "class": "mail-state-icon mail-state-error" }, "text": "!" },
                        { "tag": "h1", "attrs": { "class": "h4 mt-3" }, "text": "No pudimos abrir tu correo" },
                        { "tag": "p", "attrs": { "class": "text-muted" }, "text": "Intenta nuevamente. Si el problema continúa, comunícate con soporte." },
                        { "tag": "a", "attrs": { "class": "btn btn-primary", "href": "${contextPath}/mail" }, "text": "Reintentar" }
                      ] }
                    ]
                  },
                  {
                    "tag": "section",
                    "if": "loggedOut",
                    "attrs": { "class": "card mail-state-card" },
                    "children": [
                      { "tag": "div", "attrs": { "class": "card-body p-4" }, "children": [
                        { "tag": "span", "attrs": { "class": "mail-state-icon" }, "text": "✓" },
                        { "tag": "h1", "attrs": { "class": "h4 mt-3" }, "text": "Sesión cerrada" },
                        { "tag": "p", "attrs": { "class": "text-muted" }, "text": "Cerraste tu sesión de Gator Mail de forma segura." },
                        { "tag": "a", "attrs": { "class": "btn btn-primary", "href": "${contextPath}/oauth/login" }, "text": "Volver a entrar" }
                      ] }
                    ]
                  }
                ]
              },
              { "tag": "nav", "if": "composeAction", "attrs": { "class": "mail-action-bar", "aria-label": "Acciones de correo" }, "children": [
                { "tag": "div", "if": "mailboxView", "attrs": { "class": "mail-action-pager", "aria-label": "Paginación del buzón" }, "children": [
                  { "tag": "span", "attrs": { "class": "mail-page-summary" }, "text": "${pageSummary}" },
                  { "tag": "div", "attrs": { "class": "mail-page-sizes", "aria-label": "Mensajes por página" }, "children": [
                    { "tag": "span", "text": "Por página:" },
                    { "tag": "a", "each": "pageSizes", "as": "size", "attrs": { "class": "mail-page-size ${size.className}", "href": "${size.href}" }, "text": "${size.label}" }
                  ] },
                  { "tag": "div", "attrs": { "class": "mail-page-nav" }, "children": [
                    { "tag": "a", "if": "hasPrevious", "attrs": { "class": "btn btn-sm btn-outline-secondary", "href": "${previousHref}", "title": "Página anterior" }, "children": [
                      { "tag": "span", "attrs": { "class": "fas fa-chevron-left", "aria-hidden": "true" } }
                    ] },
                    { "tag": "a", "if": "hasNext", "attrs": { "class": "btn btn-sm btn-outline-secondary", "href": "${nextHref}", "title": "Página siguiente" }, "children": [
                      { "tag": "span", "attrs": { "class": "fas fa-chevron-right", "aria-hidden": "true" } }
                    ] }
                  ] }
                ] },
                { "tag": "div", "attrs": { "class": "mail-action-buttons" }, "children": [
                  { "tag": "a", "attrs": { "class": "btn btn-primary", "href": "${contextPath}/mail?action=compose" }, "children": [
                    { "tag": "span", "attrs": { "class": "fas fa-pen", "aria-hidden": "true" } },
                    { "tag": "span", "text": "Redactar" }
                  ] },
                  { "tag": "button", "if": "mailboxView", "attrs": { "class": "btn btn-danger", "id": "mail-delete-selected", "type": "submit", "form": "mail-bulk-form", "disabled": "true" }, "children": [
                    { "tag": "span", "attrs": { "class": "fas fa-trash-alt", "aria-hidden": "true" } },
                    { "tag": "span", "text": "Eliminar seleccionados" }
                  ] }
                ] }
              ] }
            ]
          }
        ]
      }
    ]
  }
}
